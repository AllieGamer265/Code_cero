    @keyframes gc-exhaust-flare{0%,100%{transform:scaleY(0.8) scaleX(0.9);opacity:0.6}30%{transform:scaleY(1.2) scaleX(1.1);opacity:1}60%{transform:scaleY(0.95) scaleX(0.95);opacity:0.8}}
